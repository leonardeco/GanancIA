# =============================================================
# GanancIA API — Variables de Entorno
# Copia este archivo como .env y completa los valores reales
# =============================================================

# ──────────────────────────────────
# BASE DE DATOS
# ──────────────────────────────────
# PostgreSQL + TimescaleDB (Railway)
DATABASE_URL=postgresql://user:password@host:5432/ganancia_db

# ──────────────────────────────────
# AUTENTICACIÓN
# ──────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio_en_produccion

# ──────────────────────────────────
# INTELIGENCIA ARTIFICIAL
# ──────────────────────────────────
# Clave de API de Anthropic (claude.ai/settings)
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────
# PAGOS (Stripe)
# ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_CADENA=price_...

# ──────────────────────────────────
# WHATSAPP BUSINESS API (Meta)
# ──────────────────────────────────
WHATSAPP_ACCESS_TOKEN=EAA...
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_VERIFY_TOKEN=mi_token_de_verificacion

# ──────────────────────────────────
# POS — SQUARE
# ──────────────────────────────────
SQUARE_APP_ID=sq0idp-...
SQUARE_APP_SECRET=sq0csp-...
SQUARE_WEBHOOK_SIGNATURE_KEY=...

# ──────────────────────────────────
# CACHÉ / COLAS (Redis)
# ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────
# FRONTEND (CORS)
# ──────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────
# SERVIDOR
# ──────────────────────────────────
PORT=4000
NODE_ENV=development
